{
  "name": "f1-pulse",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "npx playwright test",
    "test:deploy": "npx playwright test e2e/post-deploy.spec.ts --project=chromium-dark --project=chromium-light",
    "test:smoke": "npx playwright test e2e/smoke.spec.ts --project=chromium-dark",
    "test:screenshots": "npx playwright test e2e/post-deploy.spec.ts && echo '✅ Screenshots saved to e2e/screenshots/'",
    "test:report": "npx playwright show-report"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.0.6",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.383.0",
    "next": "^14.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.12.0",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10",
    "eslint": "^8",
    "eslint-config-next": "14.2.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.0",
    "typescript": "^5"
  }
}
